<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Student Dashboard | CHCCI</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary-bg: #0f172a;    
            --sidebar-bg: #1e293b;   
            --accent-purple: #8b5cf6; 
            --accent-pink: #ec4899;   
            --text-main: #f1f5f9;
            --text-muted: #94a3b8;
            --card-bg: #1e293b;
            --sidebar-width: 260px;
        }

        html { scroll-behavior: smooth; }

        body {
            font-family: 'Inter', sans-serif;
            margin: 0;
            display: flex;
            background-color: var(--primary-bg);
            color: var(--text-main);
        }

        /* --- Modern Sidebar --- */
        .sidebar {
            width: var(--sidebar-width);
            height: 100vh;
            background-color: var(--sidebar-bg);
            position: fixed;
            left: 0;
            top: 0;
            padding: 20px;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            border-right: 1px solid rgba(255,255,255,0.05);
            box-sizing: border-box;
            z-index: 1000; 
            pointer-events: auto; 
        }

        .sidebar-brand h2 {
            font-size: 1.25rem;
            font-weight: 700;
            margin: 0;
            padding: 20px 10px;
            background: linear-gradient(to right, var(--accent-purple), var(--accent-pink));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .nav-menu {
            display: flex;
            flex-direction: column;
            gap: 5px;
            margin-top: 20px;
        }

        .sidebar a {
            padding: 12px 15px;
            text-decoration: none;
            color: var(--text-main);
            border-radius: 10px;
            transition: 0.3s;
            font-size: 0.95rem;
            display: flex;
            align-items: center;
            gap: 12px;
            cursor: pointer;
            z-index: 1001;
            position: relative;
        }

        .sidebar a:hover {
            background: rgba(139, 92, 246, 0.1);
            color: var(--accent-purple);
        }

        .sidebar-footer {
            padding-top: 20px;
            border-top: 1px solid rgba(255,255,255,0.1);
            margin-bottom: 10px;
        }

        .footer-label {
            font-size: 0.7rem;
            text-transform: uppercase;
            color: var(--text-muted);
            letter-spacing: 1px;
            margin-bottom: 10px;
            padding-left: 15px;
        }

        .logout-link {
            color: #f87171 !important; 
            margin-top: 5px;
        }

        .logout-link:hover {
            background: rgba(248, 113, 113, 0.1) !important;
        }

        /* --- Main Content --- */
        .main-content {
            margin-left: var(--sidebar-width);
            padding: 40px;
            width: calc(100% - var(--sidebar-width));
        }

        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 40px;
        }

        .header h1 { font-size: 1.8rem; font-weight: 700; margin: 0; }
        .header h1 span { color: var(--accent-purple); }

        /* --- Stat Cards --- */
        .stat-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
            gap: 20px;
            margin-bottom: 40px;
        }

        .stat-card {
            background: var(--card-bg);
            padding: 24px;
            border-radius: 16px;
            border: 1px solid rgba(255,255,255,0.05);
            position: relative;
            overflow: hidden;
        }

        .stat-card h3 {
            color: var(--text-muted);
            font-size: 0.875rem;
            text-transform: uppercase;
            margin-bottom: 10px;
        }

        .stat-card .value {
            font-size: 1.5rem;
            font-weight: 700;
        }

        .stat-card::after {
            content: '';
            position: absolute;
            top: 0; left: 0; width: 4px; height: 100%;
            background: var(--accent-purple);
        }

        /* --- Tables & Cards --- */
        .section-title {
            font-size: 1.25rem;
            font-weight: 600;
            margin: 40px 0 20px 0;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .content-card {
            background: var(--card-bg);
            border-radius: 16px;
            padding: 25px;
            margin-bottom: 30px;
            border: 1px solid rgba(255,255,255,0.05);
            overflow-x: auto;
        }

        .data-table {
            width: 100%;
            border-collapse: collapse;
        }

        .data-table th {
            text-align: left;
            color: var(--text-muted);
            font-size: 0.75rem;
            text-transform: uppercase;
            padding: 12px;
            border-bottom: 1px solid rgba(255,255,255,0.1);
        }

        .data-table td {
            padding: 15px 12px;
            border-bottom: 1px solid rgba(255,255,255,0.05);
            font-size: 0.95rem;
        }

        .grade-badge {
            background: rgba(139, 92, 246, 0.2);
            color: var(--accent-purple);
            padding: 4px 10px;
            border-radius: 6px;
            font-weight: 600;
        }

        .announcement-box {
            border-left: 4px solid var(--accent-pink);
            padding-left: 20px;
            margin-bottom: 25px;
        }

        .post-img {
            width: calc(50% - 5px);
            max-height: 300px;
            border-radius: 12px;
            object-fit: cover;
            margin-top: 10px;
        }
    </style>
</head>
<body>

<div class="sidebar">
    <div class="top-group">
        <div class="sidebar-brand">
            <h2>StudentHub</h2>
        </div>

        <nav class="nav-menu">
            <a href="/student-dashboard">🏠 Dashboard</a>
            <a href="#schedule-section">📅 Class Schedule</a>
            <a href="#grades-section">📊 My Grades</a>
        </nav>
    </div>

    <div class="sidebar-footer">
        <div class="footer-label">Account</div>
        <a href="/student-profile" class="account-link">
            <div style="display: flex; align-items: center; gap: 10px;">
                <div style="width: 32px; height: 32px; background: var(--accent-purple); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 0.85rem; color: white; font-weight: bold;">
                    <%= user.charAt(0).toUpperCase() %>
                </div>
                <span>👤 Profile</span>
            </div>
        </a>
        <a href="/logout" class="logout-link">🚪 Logout</a>
    </div>
</div>

<div class="main-content">
    <div class="header">
        <h1>Welcome back, <span><%= user %></span> 👋</h1>
    </div>

    <div class="stat-grid">
        <div class="stat-card">
            <h3>Current GPA</h3>
            <div class="value">
                <% 
                   if (grades.length > 0) { 
                      let sum = 0;
                      grades.forEach(g => sum += parseFloat(g.grade_value));
                      %><%= (sum / grades.length).toFixed(2) %><%
                   } else { 
                      %>N/A<% 
                   } 
                %>
            </div>
        </div>

        <div class="stat-card" style="--accent-purple: var(--accent-pink)">
            <h3>Status</h3>
            <div class="value">Enrolled</div> </div>

        <div class="stat-card">
            <h3>Course / College</h3>
            <div class="value"><%= student.course %></div> </div>

        <div class="stat-card" style="--accent-purple: #10b981">
            <h3>Year Level</h3>
            <div class="value">
                <%= student.year_level %>
                <%= student.year_level == 1 ? 'st' : student.year_level == 2 ? 'nd' : student.year_level == 3 ? 'rd' : 'th' %> Year
            </div> </div>
    </div>

    <h2 class="section-title" id="schedule-section">📅 Class Schedule</h2>
    <div class="content-card">
        <table class="data-table">
            <thead>
                <tr>
                    <th>Day</th>
                    <th>Subject</th>
                    <th>Time</th>
                    <th>Room</th>
                </tr>
            </thead>
            <tbody>
                <% if (typeof schedules !== 'undefined' && schedules.length > 0) { %>
                    <% schedules.forEach(s => { %>
                        <tr>
                            <td style="font-weight: 600; color: var(--accent-purple);"><%= s.day_of_week %></td>
                            <td>
                                <strong><%= s.subject_code %></strong><br>
                                <span style="font-size: 0.85rem; color: var(--text-muted);"><%= s.subject_name %></span>
                            </td>
                            <td style="color: var(--accent-pink); font-weight: 500;"><%= s.start_time %> - <%= s.end_time %></td>
                            <td><span class="grade-badge" style="background: rgba(236, 72, 153, 0.1); color: var(--accent-pink);"><%= s.room %></span></td>
                        </tr>
                    <% }) %>
                <% } else { %>
                    <tr><td colspan="4" style="text-align: center; padding: 40px; color: var(--text-muted);">No class schedule found for your current year and course.</td></tr>
                <% } %>
            </tbody>
        </table>
    </div>

    <h2 class="section-title" id="grades-section">📊 My Grades</h2>
    <div class="content-card">
        <table class="data-table">
            <thead>
                <tr>
                    <th>Subject</th>
                    <th style="text-align: center;">Grade</th>
                </tr>
            </thead>
            <tbody>
                <% if (typeof grades !== 'undefined' && grades.length > 0) { %>
                    <% grades.forEach(g => { %>
                        <tr>
                            <td><%= g.subject_name %></td>
                            <td style="text-align: center;"><span class="grade-badge"><%= g.grade_value %></span></td>
                        </tr>
                    <% }) %>
                <% } else { %>
                    <tr><td colspan="2" style="text-align: center; padding: 40px; color: var(--text-muted);">No grades encoded yet.</td></tr>
                <% } %>
            </tbody>
        </table>
    </div>

    <h2 class="section-title">📢 Recent Announcements</h2>
    <div class="content-card">
        <% if (announcements.length > 0) { %>
            <% announcements.forEach(post => { %>
                <div class="announcement-box">
                    <h3 style="margin: 0 0 5px 0;"><%= post.title %></h3>
                    <p style="color: var(--text-muted); line-height: 1.6; margin-bottom: 10px;"><%= post.message %></p>
                    
                    <% if (post.image) { %>
                        <div class="image-gallery">
                            <% try { 
                                let images = JSON.parse(post.image); 
                                images.forEach(img => { %>
                                    <img src="/uploads/<%= img %>" class="post-img" alt="Announcement Image">
                                <% }); 
                            } catch(e) { %>
                                <img src="/uploads/<%= post.image %>" class="post-img" alt="Announcement Image">
                            <% } %>
                        </div>
                    <% } %>
                    <small style="color: var(--text-muted); display: block; margin-top: 10px;">📅 Published on: <%= new Date(post.created_at).toLocaleDateString() %></small>
                </div>
            <% }); %>
        <% } else { %>
            <p style="color: var(--text-muted);">No new announcements to show.</p>
        <% } %>
    </div>
</div>

</body>
</html>