<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Student Dashboard | CHCCI</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary-bg: #0f172a;    
            --sidebar-bg: #1e293b;   
            --accent-purple: #8b5cf6; 
            --accent-pink: #ec4899;   
            --text-main: #f1f5f9;
            --text-muted: #94a3b8;
            --card-bg: #1e293b;
            --sidebar-width: 260px;
        }

        html { scroll-behavior: smooth; }

        body {
            font-family: 'Inter', sans-serif;
            margin: 0;
            display: flex;
            background-color: var(--primary-bg);
            color: var(--text-main);
            min-height: 100vh;
        }

        /* --- Mobile Toggle Button --- */
        .mobile-toggle {
            display: none;
            position: fixed;
            top: 20px;
            right: 20px;
            z-index: 2000;
            background: var(--accent-purple);
            color: white;
            border: none;
            padding: 10px 15px;
            border-radius: 8px;
            cursor: pointer;
            box-shadow: 0 4px 10px rgba(0,0,0,0.3);
        }

        /* --- Modern Sidebar --- */
        .sidebar {
            width: var(--sidebar-width);
            height: 100vh;
            background-color: var(--sidebar-bg);
            position: fixed;
            left: 0;
            top: 0;
            padding: 20px;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            border-right: 1px solid rgba(255,255,255,0.05);
            box-sizing: border-box;
            z-index: 1000; 
            transition: transform 0.3s ease;
        }

        .sidebar-brand h2 {
            font-size: 1.25rem;
            font-weight: 700;
            margin: 0;
            padding: 20px 10px;
            background: linear-gradient(to right, var(--accent-purple), var(--accent-pink));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .nav-menu {
            display: flex;
            flex-direction: column;
            gap: 5px;
            margin-top: 20px;
        }

        .sidebar a {
            padding: 12px 15px;
            text-decoration: none;
            color: var(--text-main);
            border-radius: 10px;
            transition: 0.3s;
            font-size: 0.95rem;
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .sidebar a:hover {
            background: rgba(139, 92, 246, 0.1);
            color: var(--accent-purple);
        }

        .sidebar-footer {
            padding-top: 20px;
            border-top: 1px solid rgba(255,255,255,0.1);
            margin-bottom: 10px;
        }

        .footer-label {
            font-size: 0.7rem;
            text-transform: uppercase;
            color: var(--text-muted);
            letter-spacing: 1px;
            margin-bottom: 10px;
            padding-left: 15px;
        }

        .logout-link { color: #f87171 !important; margin-top: 5px; }
        .logout-link:hover { background: rgba(248, 113, 113, 0.1) !important; }

        /* --- Main Content --- */
        .main-content {
            margin-left: var(--sidebar-width);
            padding: 40px;
            width: calc(100% - var(--sidebar-width));
            box-sizing: border-box;
            transition: margin-left 0.3s ease;
        }

        .header { margin-bottom: 40px; }
        .header h1 { font-size: 1.8rem; font-weight: 700; margin: 0; }
        .header h1 span { color: var(--accent-purple); }

        /* --- Stat Cards --- */
        .stat-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
            gap: 20px;
            margin-bottom: 40px;
        }

        .stat-card {
            background: var(--card-bg);
            padding: 24px;
            border-radius: 16px;
            border: 1px solid rgba(255,255,255,0.05);
            position: relative;
        }

        .stat-card .value { font-size: 1.5rem; font-weight: 700; }

        /* --- Tables & Cards --- */
        .content-card {
            background: var(--card-bg);
            border-radius: 16px;
            padding: 20px;
            margin-bottom: 30px;
            border: 1px solid rgba(255,255,255,0.05);
            overflow-x: auto; /* Required for table responsiveness */
        }

        .data-table { width: 100%; border-collapse: collapse; min-width: 500px; }
        .data-table th, .data-table td { padding: 12px; text-align: left; border-bottom: 1px solid rgba(255,255,255,0.05); }

        .grade-badge {
            background: rgba(139, 92, 246, 0.2);
            color: var(--accent-purple);
            padding: 4px 10px;
            border-radius: 6px;
            font-weight: 600;
        }

        .post-img {
            width: 48%;
            max-height: 300px;
            border-radius: 12px;
            object-fit: cover;
            margin: 1% 1% 0 0;
        }

        /* --- RESPONSIVE MEDIA QUERIES --- */
        @media (max-width: 992px) {
            .mobile-toggle { display: block; } /* Show menu button */
            
            .sidebar {
                transform: translateX(-100%); /* Hide sidebar */
            }

            .sidebar.active {
                transform: translateX(0); /* Show sidebar when toggled */
            }

            .main-content {
                margin-left: 0;
                width: 100%;
                padding: 80px 20px 20px 20px; /* Space for mobile button */
            }

            .stat-grid { grid-template-columns: 1fr; } /* Stack cards on mobile */
            
            .post-img { width: 100%; margin-right: 0; } /* Stack announcement images */
        }
    </style>
</head>
<body>

<button class="mobile-toggle" onclick="toggleSidebar()">☰ Menu</button>

<div class="sidebar" id="sidebar">
    <div class="top-group">
        <div class="sidebar-brand">
            <h2>StudentHub</h2>
        </div>

        <nav class="nav-menu">
            <a href="/student-dashboard" onclick="toggleSidebar()">🏠 Dashboard</a>
            <a href="#schedule-section" onclick="toggleSidebar()">📅 Class Schedule</a>
            <a href="#grades-section" onclick="toggleSidebar()">📊 My Grades</a>
        </nav>
    </div>

    <div class="sidebar-footer">
        <div class="footer-label">Account</div>
        <a href="/student-profile" class="account-link">
            <div style="display: flex; align-items: center; gap: 10px;">
                <div style="width: 32px; height: 32px; background: var(--accent-purple); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 0.85rem; color: white; font-weight: bold;">
                    <%= user.charAt(0).toUpperCase() %>
                </div>
                <span>👤 Profile</span>
            </div>
        </a>
        <a href="/logout" class="logout-link">🚪 Logout</a>
    </div>
</div>

<div class="main-content">
    <div class="header">
        <h1>Welcome back, <span><%= user %></span> 👋</h1>
    </div>

    <div class="stat-grid">
        <div class="stat-card">
            <h3 style="font-size: 0.8rem; color: var(--text-muted); text-transform: uppercase;">Current GPA</h3>
            <div class="value">
                <% if (grades.length > 0) { 
                      let sum = 0;
                      grades.forEach(g => sum += parseFloat(g.grade_value));
                      %><%= (sum / grades.length).toFixed(2) %><%
                   } else { %>N/A<% } %>
            </div>
        </div>

        <div class="stat-card">
            <h3 style="font-size: 0.8rem; color: var(--text-muted); text-transform: uppercase;">Status</h3>
            <div class="value">Enrolled</div>
        </div>

        <div class="stat-card">
            <h3 style="font-size: 0.8rem; color: var(--text-muted); text-transform: uppercase;">Course</h3>
            <div class="value"><%= student.course %></div>
        </div>

        <div class="stat-card">
            <h3 style="font-size: 0.8rem; color: var(--text-muted); text-transform: uppercase;">Year Level</h3>
            <div class="value"><%= student.year_level %><%= student.year_level == 1 ? 'st' : student.year_level == 2 ? 'nd' : student.year_level == 3 ? 'rd' : 'th' %> Year</div>
        </div>
    </div>

    <h2 class="section-title" id="schedule-section">📅 Class Schedule</h2>
    <div class="content-card">
        <table class="data-table">
            <thead>
                <tr>
                    <th>Day</th>
                    <th>Subject</th>
                    <th>Time</th>
                    <th>Room</th>
                </tr>
            </thead>
            <tbody>
                <% if (typeof schedules !== 'undefined' && schedules.length > 0) { %>
                    <% schedules.forEach(s => { %>
                        <tr>
                            <td style="font-weight: 600; color: var(--accent-purple);"><%= s.day_of_week %></td>
                            <td><strong><%= s.subject_code %></strong><br><small><%= s.subject_name %></small></td>
                            <td style="color: var(--accent-pink);"><%= s.start_time %> - <%= s.end_time %></td>
                            <td><span class="grade-badge" style="background: rgba(236, 72, 153, 0.1); color: var(--accent-pink);"><%= s.room %></span></td>
                        </tr>
                    <% }) %>
                <% } else { %>
                    <tr><td colspan="4" style="text-align: center; padding: 20px;">No schedule found.</td></tr>
                <% } %>
            </tbody>
        </table>
    </div>

    <h2 class="section-title" id="grades-section">📊 My Grades</h2>
    <div class="content-card">
        <table class="data-table">
            <thead>
                <tr>
                    <th>Subject</th>
                    <th style="text-align: center;">Grade</th>
                </tr>
            </thead>
            <tbody>
                <% if (typeof grades !== 'undefined' && grades.length > 0) { %>
                    <% grades.forEach(g => { %>
                        <tr>
                            <td><%= g.subject_name %></td>
                            <td style="text-align: center;"><span class="grade-badge"><%= g.grade_value %></span></td>
                        </tr>
                    <% }) %>
                <% } else { %>
                    <tr><td colspan="2" style="text-align: center; padding: 20px;">No grades encoded.</td></tr>
                <% } %>
            </tbody>
        </table>
    </div>

    <h2 class="section-title">📢 Announcements</h2>
<div class="content-card">
    <% announcements.forEach(post => { %>
        <div style="border-left: 4px solid var(--accent-pink); padding-left: 15px; margin-bottom: 30px; padding-bottom: 10px; border-bottom: 1px solid rgba(255,255,255,0.05);">
            <h3 style="margin: 0; color: var(--accent-purple);"><%= post.title %></h3>
            <p style="color: var(--text-muted); font-size: 0.95rem; line-height: 1.5;"><%= post.message %></p>
            
            <div style="display: flex; flex-wrap: wrap; gap: 10px; margin-top: 10px;">
                <% if (post.image) { 
                    try { 
                        // We parse the JSON string back into a real Javascript Array
                        let images = JSON.parse(post.image); 
                        if (Array.isArray(images)) {
                            images.forEach(imgName => { %>
                                <img src="/uploads/<%= imgName %>" class="post-img" alt="Announcement Image">
                            <% });
                        }
                    } catch (e) { 
                        // Fallback if the data isn't JSON (for older posts)
                        %> <img src="/uploads/<%= post.image %>" class="post-img"> <% 
                    } 
                } %>
            </div>
            <small style="color: var(--text-muted); display: block; margin-top: 10px;">
                Posted on: <%= new Date(post.created_at).toLocaleDateString() %>
            </small>
        </div>
    <% }) %>
</div>

<script>
    function toggleSidebar() {
        document.getElementById('sidebar').classList.toggle('active');
    }
</script>

</body>
</html>