<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Teacher Dashboard | StudentHub</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary-bg: #0f172a;    
            --sidebar-bg: #1e293b;   
            --accent-purple: #8b5cf6; 
            --accent-pink: #ec4899;   
            --text-main: #f1f5f9;
            --text-muted: #94a3b8;
            --card-bg: #1e293b;
            --sidebar-width: 260px;
            --input-bg: #0f172a;
        }

        body {
            font-family: 'Inter', sans-serif;
            margin: 0;
            display: flex;
            background-color: var(--primary-bg);
            color: var(--text-main);
        }

        /* --- Sidebar --- */
        .sidebar {
            width: var(--sidebar-width);
            height: 100vh;
            background-color: var(--sidebar-bg);
            position: fixed;
            left: 0; top: 0;
            padding: 20px;
            display: flex;
            flex-direction: column;
            border-right: 1px solid rgba(255,255,255,0.05);
            box-sizing: border-box;
        }

        .sidebar-brand h2 {
            font-size: 1.25rem;
            font-weight: 700;
            background: linear-gradient(to right, var(--accent-purple), var(--accent-pink));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            margin-bottom: 30px;
        }

        .nav-menu a {
            padding: 12px 15px;
            text-decoration: none;
            color: var(--text-main);
            border-radius: 10px;
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 5px;
            transition: 0.3s;
        }

        .nav-menu a:hover {
            background: rgba(139, 92, 246, 0.1);
            color: var(--accent-purple);
        }

        .logout-link {
            margin-top: auto;
            color: #f87171 !important;
            text-decoration: none;
            padding: 12px 15px;
        }

        /* --- Main Content --- */
        .main-content {
            margin-left: var(--sidebar-width);
            padding: 40px;
            width: calc(100% - var(--sidebar-width));
        }

        .header h1 { font-size: 1.8rem; margin: 0 0 40px 0; }
        .header h1 span { color: var(--accent-purple); }

        .dashboard-grid {
            display: grid;
            grid-template-columns: 1fr 1.5fr;
            gap: 30px;
        }

        .content-card {
            background: var(--card-bg);
            border-radius: 20px;
            padding: 30px;
            border: 1px solid rgba(255,255,255,0.05);
            box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.3);
        }

        .card-title {
            font-size: 1.2rem;
            font-weight: 600;
            margin-bottom: 25px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        /* --- Form Elements --- */
        label {
            display: block;
            font-size: 0.85rem;
            color: var(--text-muted);
            margin-bottom: 8px;
        }

        select, input {
            width: 100%;
            padding: 14px;
            margin-bottom: 20px;
            background: var(--input-bg);
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 12px;
            color: white;
            font-family: inherit;
            box-sizing: border-box;
        }

        select:focus, input:focus {
            outline: none;
            border-color: var(--accent-purple);
        }

        .btn-submit {
            background: linear-gradient(to right, var(--accent-purple), var(--accent-pink));
            color: white;
            border: none;
            padding: 15px;
            border-radius: 12px;
            width: 100%;
            font-weight: 700;
            cursor: pointer;
            transition: transform 0.2s;
        }

        .btn-submit:hover { transform: translateY(-2px); }

        /* --- Table --- */
        .data-table { width: 100%; border-collapse: collapse; }
        .data-table th {
            text-align: left;
            color: var(--text-muted);
            font-size: 0.75rem;
            text-transform: uppercase;
            padding: 12px;
            border-bottom: 1px solid rgba(255,255,255,0.1);
        }

        .data-table td {
            padding: 15px 12px;
            border-bottom: 1px solid rgba(255,255,255,0.05);
            font-size: 0.95rem;
        }

        .grade-badge {
            background: rgba(139, 92, 246, 0.2);
            color: var(--accent-purple);
            padding: 6px 12px;
            border-radius: 8px;
            font-weight: 700;
        }
    </style>
</head>
<body>

    <div class="sidebar">
        <div class="sidebar-brand">
            <h2>StudentHub</h2>
        </div>
        <nav class="nav-menu">
            <a href="/teacher-dashboard">✍️ Input Grades</a>
            </nav>
        <a href="/logout" class="logout-link">🚪 Logout</a>
    </div>

    <div class="main-content">
        <div class="header">
            <h1>Welcome, <span>Coach <%= user %></span>! 🎓</h1>
        </div>

        <div class="dashboard-grid">
            <div class="content-card" style="border-top: 4px solid var(--accent-purple);">
                <div class="card-title">📝 Enter Student Grade</div>
                <form action="/submit-grade" method="POST">
                    <label>Select Student:</label>
                    <select name="student_id" required>
                        <option value="">-- Choose Student --</option>
                        <% students.forEach(student => { %>
                            <option value="<%= student.id %>"><%= student.first_name %> <%= student.last_name %></option>
                        <% }); %>
                    </select>

                    <label>Subject:</label>
                    <input type="text" name="subject_name" placeholder="e.g. Data Structures" required>

                    <label>Grade (1.0 - 5.0):</label>
                    <input type="number" step="0.25" name="grade_value" min="1.0" max="5.0" placeholder="1.25" required>

                    <button type="submit" class="btn-submit">Post Grade</button>
                </form>
            </div>

            <div class="content-card" style="border-top: 4px solid var(--accent-pink);">
                <div class="card-title">📊 Recently Encoded Grades</div>
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Student</th>
                            <th>Subject</th>
                            <th style="text-align: center;">Grade</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (typeof recentGrades !== 'undefined' && recentGrades.length > 0) { %>
                            <% recentGrades.forEach(item => { %>
                                <tr>
                                    <td><strong><%= item.first_name %> <%= item.last_name %></strong></td>
                                    <td style="color: var(--text-muted);"><%= item.subject_name %></td>
                                    <td style="text-align: center;"><span class="grade-badge"><%= item.grade_value %></span></td>
                                </tr>
                            <% }); %>
                        <% } else { %>
                            <tr>
                                <td colspan="3" style="text-align:center; color: var(--text-muted); padding: 40px;">No grades encoded recently.</td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</body>
</html>