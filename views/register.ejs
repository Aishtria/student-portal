<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>StudentHub | Create Account</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg-dark: #0b0e14;
            --card-bg: #111827;
            --accent-purple: #8b5cf6;
            --input-bg: #1f2937;
            --text-main: #f1f5f9;
            --text-muted: #94a3b8;
        }

        body { 
            background-color: var(--bg-dark);
            background-image: 
                radial-gradient(at 0% 0%, rgba(139, 92, 246, 0.15) 0px, transparent 50%),
                radial-gradient(at 100% 100%, rgba(59, 130, 246, 0.1) 0px, transparent 50%);
            font-family: 'Inter', sans-serif; 
            height: 100vh; 
            display: flex; 
            justify-content: center; 
            align-items: center; 
            margin: 0;
            color: var(--text-main);
        }

        .reg-card { 
            background: var(--card-bg); 
            padding: 2.5rem; 
            border-radius: 24px; 
            box-shadow: 0 20px 50px rgba(0,0,0,0.5); 
            width: 420px; 
            border: 1px solid rgba(255,255,255,0.05);
        }

        .logo-section {
            text-align: center;
            margin-bottom: 30px;
        }

        .logo-section h2 {
            margin: 10px 0 5px 0;
            font-weight: 700;
            letter-spacing: -0.5px;
        }

        .logo-section h2 span {
            color: var(--accent-purple);
        }

        .logo-section p {
            color: var(--text-muted);
            font-size: 0.9rem;
            margin: 0;
        }

        label { 
            font-size: 0.8rem; 
            color: var(--text-muted); 
            font-weight: 600; 
            text-transform: uppercase;
            letter-spacing: 0.5px;
            display: block;
            margin-bottom: 8px;
        }

        input, select { 
            width: 100%; 
            padding: 12px 16px; 
            margin-bottom: 15px; 
            background: var(--input-bg);
            border: 1px solid rgba(255,255,255,0.1); 
            border-radius: 12px; 
            box-sizing: border-box; 
            color: white;
            transition: 0.3s;
            font-size: 0.95rem;
        }

        input:focus, select:focus {
            outline: none;
            border-color: var(--accent-purple);
            background: #262f3f;
            box-shadow: 0 0 0 4px rgba(139, 92, 246, 0.1);
        }

        input::placeholder {
            color: #64748b;
        }

        hr { 
            border: 0; 
            border-top: 1px solid rgba(255,255,255,0.05); 
            margin: 20px 0; 
        }

        button { 
            width: 100%; 
            padding: 14px; 
            background: linear-gradient(135deg, #8b5cf6, #6366f1); 
            color: white; 
            border: none; 
            border-radius: 12px; 
            cursor: pointer; 
            font-weight: 700; 
            font-size: 1rem;
            margin-top: 10px;
            transition: 0.3s;
        }

        button:hover { 
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(139, 92, 246, 0.3);
            filter: brightness(1.1);
        }

        .links { 
            text-align: center; 
            margin-top: 20px; 
            font-size: 0.9rem; 
        }

        .links a {
            color: var(--accent-purple);
            text-decoration: none;
            font-weight: 500;
        }

        .links a:hover {
            text-decoration: underline;
        }

        /* Grouping fields for cleaner look */
        .name-row {
            display: flex;
            gap: 10px;
        }
    </style>
</head>
<body>

    <div class="reg-card">
        <div class="logo-section">
            <h2 id="regTitle">Student<span>Hub</span></h2>
            <p>Create your account to get started</p>
        </div>

        <form action="/register" method="POST">
            <label>Account Type</label>
            <select name="role" id="roleSelect" onchange="toggleFields()">
                <option value="student">Student</option>
                <option value="teacher">Teacher</option>
            </select>

            <label>Login Credentials</label>
            <input type="text" name="username" placeholder="ID Number / Username" required>
            <input type="password" name="password" placeholder="Create Password" required>
            
            <hr>
            
            <label>Personal Information</label>
            <div class="name-row">
                <input type="text" name="first_name" placeholder="First Name" required>
                <input type="text" name="last_name" placeholder="Last Name" required>
            </div>

            <div id="studentFields">
                <input type="text" name="course" id="courseInput" placeholder="Course (e.g. BSCS)" required>
                <select name="year_level">
                    <option value="1">1st Year</option>
                    <option value="2">2nd Year</option>
                    <option value="3">3rd Year</option>
                    <option value="4">4th Year</option>
                </select>
            </div>

            <button type="submit">Register Account</button>
        </form>
        <div class="links"><a href="/">Already have an account? Login</a></div>
    </div>

    <script>
        function toggleFields() {
            const role = document.getElementById('roleSelect').value;
            const studentFields = document.getElementById('studentFields');
            const courseInput = document.getElementById('courseInput');
            const regTitle = document.getElementById('regTitle');

            if (role === 'teacher') {
                studentFields.style.display = 'none';
                courseInput.removeAttribute('required');
                regTitle.innerHTML = "Teacher<span>Portal</span>";
            } else {
                studentFields.style.display = 'block';
                courseInput.setAttribute('required', '');
                regTitle.innerHTML = "Student<span>Hub</span>";
            }
        }
    </script>
</body>
</html>