<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>StudentHub | Login</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg-dark: #0f172a;
            --card-bg: #1e293b;
            --accent-purple: #8b5cf6;
            --accent-blue: #3b82f6;
            --input-bg: #f1f5f9;
            --text-main: #f8fafc;
            --text-muted: #94a3b8;
        }

        body {
            background-color: var(--bg-dark);
            font-family: 'Inter', sans-serif;
            height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            margin: 0;
            color: var(--text-main);
        }

        .login-container {
            display: flex;
            background: #111827;
            width: 850px;
            height: 550px;
            border-radius: 24px;
            overflow: hidden;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
            border: 1px solid rgba(255, 255, 255, 0.05);
        }

        /* Left Side - Branding */
        .brand-side {
            flex: 1;
            background: radial-gradient(circle at top left, rgba(139, 92, 246, 0.2), transparent),
                        linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            padding: 40px;
            text-align: center;
            border-right: 1px solid rgba(255, 255, 255, 0.05);
        }

        .brand-side h1 { font-size: 2.5rem; margin-bottom: 10px; }
        .brand-side h1 span { color: var(--accent-blue); }
        .brand-side p { color: var(--text-muted); margin-bottom: 30px; }

        /* Right Side - Form */
        .form-side {
            flex: 1;
            padding: 50px;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        .role-selector {
            display: flex;
            background: #1f2937;
            padding: 5px;
            border-radius: 12px;
            margin-bottom: 30px;
        }

        .role-btn {
            flex: 1;
            padding: 12px;
            border-radius: 8px;
            text-align: center;
            font-size: 0.9rem;
            cursor: pointer;
            color: var(--text-muted);
            border: none;
            background: transparent;
            transition: 0.3s;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
        }

        .role-btn.active {
            background: #374151;
            color: white;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.2);
        }

        label { font-size: 0.75rem; color: var(--text-muted); text-transform: uppercase; letter-spacing: 1px; margin-bottom: 8px; display: block; }

        input {
            width: 100%;
            padding: 14px 16px;
            margin-bottom: 20px;
            background: var(--input-bg);
            border: 2px solid transparent;
            border-radius: 12px;
            box-sizing: border-box;
            color: #1e293b;
            font-size: 1rem;
            transition: 0.3s;
        }

        input:focus {
            outline: none;
            border-color: var(--accent-purple);
            box-shadow: 0 0 0 4px rgba(139, 92, 246, 0.1);
        }

        .btn-signin {
            width: 100%;
            padding: 14px;
            background: linear-gradient(to right, #8b5cf6, #6366f1);
            color: white;
            border: none;
            border-radius: 12px;
            font-weight: 600;
            cursor: pointer;
            font-size: 1rem;
            margin-top: 10px;
            transition: 0.3s;
        }

        .btn-signin:hover { opacity: 0.9; transform: translateY(-1px); }

        .footer-link { text-align: center; margin-top: 25px; font-size: 0.85rem; color: var(--text-muted); }
        .footer-link a { color: var(--accent-purple); text-decoration: none; font-weight: 600; }
    </style>
</head>
<body>

    <div class="login-container">
        <div class="brand-side">
            <div style="background: var(--accent-purple); width: 80px; height: 80px; border-radius: 20px; margin-bottom: 20px; display: flex; align-items: center; justify-content: center; font-size: 2rem;">🎓</div>
            <h1>Student<span>Hub</span></h1>
            <p>Your gateway to academic excellence</p>
            <div style="text-align: left; width: 100%; padding: 0 20px;">
                <p style="font-size: 0.9rem; margin: 10px 0;">📊 Track your academic progress</p>
                <p style="font-size: 0.9rem; margin: 10px 0;">📚 Browse & enroll in courses</p>
                <p style="font-size: 0.9rem; margin: 10px 0;">⚙️ Manage records with ease</p>
            </div>
        </div>

        <div class="form-side">
            <div class="role-selector">
                <button type="button" class="role-btn active" id="studentBtn" onclick="setRole('student')">
                    <span>🧑‍🎓</span> Student
                </button>
                <button type="button" class="role-btn" id="adminBtn" onclick="setRole('admin')">
                    <span>🛡️</span> Admin
                </button>
            </div>

            <h2 id="loginHeader" style="margin: 0 0 5px 0;">Student Login</h2>
            <p id="loginSubtext" style="color: var(--text-muted); font-size: 0.9rem; margin-bottom: 30px;">Access your dashboard and courses</p>

            <form action="/login" method="POST">
                <input type="hidden" name="role" id="selectedRole" value="student">

                <label id="userLabel">Username / ID Number</label>
                <input type="text" name="username" placeholder="Enter your ID" required>

                <label>Password</label>
                <input type="password" name="password" placeholder="••••••" required>

                <button type="submit" class="btn-signin">Sign In →</button>
            </form>

            <div class="footer-link">
                Don't have an account? <a href="/register">Register here</a>
            </div>
        </div>
    </div>

    <script>
        function setRole(role) {
            const studentBtn = document.getElementById('studentBtn');
            const adminBtn = document.getElementById('adminBtn');
            const roleInput = document.getElementById('selectedRole');
            const header = document.getElementById('loginHeader');
            const subtext = document.getElementById('loginSubtext');
            const userLabel = document.getElementById('userLabel');

            if (role === 'admin') {
                adminBtn.classList.add('active');
                studentBtn.classList.remove('active');
                roleInput.value = 'admin';
                
                // Update UI text for Admin
                header.innerText = "Admin Login";
                subtext.innerText = "Manage portal settings and users";
                userLabel.innerText = "Admin Username";
            } else {
                studentBtn.classList.add('active');
                adminBtn.classList.remove('active');
                roleInput.value = 'student';
                
                // Update UI text for Student
                header.innerText = "Student Login";
                subtext.innerText = "Access your dashboard and courses";
                userLabel.innerText = "Username / ID Number";
            }
        }
    </script>

</body>
</html>