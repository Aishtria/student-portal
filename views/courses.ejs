<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Course Catalog | StudentHub</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary-bg: #0b0e14;    
            --sidebar-bg: #111827;   
            --accent-purple: #8b5cf6; 
            --accent-blue: #3b82f6;
            --text-main: #f1f5f9;
            --text-muted: #94a3b8;
            --sidebar-width: 260px;
            --card-hover: rgba(139, 92, 246, 0.15);
        }

        body {
            font-family: 'Inter', sans-serif;
            margin: 0;
            display: flex;
            background-color: var(--primary-bg);
            color: var(--text-main);
            min-height: 100vh;
        }

        /* --- Sidebar --- */
        .sidebar {
            width: var(--sidebar-width);
            height: 100vh;
            background-color: var(--sidebar-bg);
            position: fixed;
            padding: 30px 20px;
            display: flex;
            flex-direction: column;
            justify-content: space-between; 
            border-right: 1px solid rgba(255,255,255,0.05);
            box-sizing: border-box;
            z-index: 1000;
        }

        .sidebar-brand h2 {
            font-size: 1.5rem;
            font-weight: 800;
            background: linear-gradient(to right, #60a5fa, var(--accent-purple));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            margin: 0 0 40px 0;
            letter-spacing: -0.5px;
        }

        .nav-menu a {
            display: flex;
            align-items: center;
            gap: 12px;
            color: var(--text-muted);
            padding: 14px 18px;
            text-decoration: none;
            border-radius: 12px;
            transition: all 0.3s ease;
            margin-bottom: 8px;
            font-weight: 500;
        }

        .nav-menu a.active {
            background: rgba(139, 92, 246, 0.1);
            color: var(--accent-purple);
            font-weight: 600;
        }

        .nav-menu a:hover:not(.active) {
            color: var(--text-main);
            background: rgba(255, 255, 255, 0.03);
        }

        .sidebar-footer {
            padding-top: 20px;
            border-top: 1px solid rgba(255,255,255,0.05);
        }

        /* --- Main Content --- */
        .main-content {
            margin-left: var(--sidebar-width);
            padding: 60px 40px;
            width: calc(100% - var(--sidebar-width));
        }

        .header h1 { font-size: 2.2rem; font-weight: 800; margin-bottom: 8px; }
        .header p { color: var(--text-muted); margin-bottom: 40px; }

        .courses-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
            gap: 24px;
        }

        .course-card {
            background: var(--sidebar-bg);
            border-radius: 24px;
            padding: 28px;
            border: 1px solid rgba(255,255,255,0.05);
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            position: relative;
            overflow: hidden;
        }

        .course-card:hover {
            transform: translateY(-8px);
            border-color: var(--accent-purple);
            box-shadow: 0 20px 30px -10px rgba(0, 0, 0, 0.5);
        }

        /* Card Header Info */
        .card-meta {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
        }

        .course-tag {
            background: rgba(59, 130, 246, 0.1);
            color: var(--accent-blue);
            padding: 6px 14px;
            border-radius: 100px;
            font-weight: 700;
            font-size: 0.7rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .room-tag {
            font-size: 0.75rem;
            color: var(--text-muted);
            background: rgba(255, 255, 255, 0.03);
            padding: 4px 10px;
            border-radius: 6px;
        }

        .course-title {
            margin: 0 0 16px 0;
            font-size: 1.25rem;
            line-height: 1.4;
            font-weight: 700;
        }

        .schedule-info {
            display: flex;
            flex-direction: column;
            gap: 10px;
            padding-top: 15px;
            border-top: 1px solid rgba(255,255,255,0.03);
        }

        .info-item {
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 0.9rem;
            color: var(--text-muted);
        }

        .info-item span.icon {
            font-size: 1.1rem;
            opacity: 0.8;
        }

        .btn-signout {
            display: block;
            width: 100%;
            padding: 14px;
            background: rgba(239, 68, 68, 0.1);
            color: #ef4444;
            text-align: center;
            text-decoration: none;
            border-radius: 14px;
            font-weight: 700;
            transition: 0.3s;
        }

        .btn-signout:hover {
            background: rgba(239, 68, 68, 0.2);
        }

        .user-avatar {
            width: 40px; 
            height: 40px; 
            background: linear-gradient(135deg, var(--accent-blue), var(--accent-purple)); 
            border-radius: 12px; 
            display: flex; 
            align-items: center; 
            justify-content: center; 
            font-weight: 800; 
            color: white;
            box-shadow: 0 4px 10px rgba(0,0,0,0.3);
        }
    </style>
</head>
<body>

<aside class="sidebar">
    <div class="top-section">
        <div class="sidebar-brand"><h2>StudentHub</h2></div>
        <nav class="nav-menu">
            <a href="/student-dashboard">🏠 Dashboard</a>
            <a href="/courses" class="active">📚 Courses</a>
            <a href="/student-profile">👤 Profile</a>
        </nav>
    </div>

    <div class="sidebar-footer">
        <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 20px; padding: 0 10px;">
            <div class="user-avatar">
                <%= user.charAt(0).toUpperCase() %>
            </div>
            <div>
                <div style="font-size: 0.9rem; font-weight: 700;"><%= user %></div>
                <div style="font-size: 0.75rem; color: var(--text-muted);">Student ID: #1024</div>
            </div>
        </div>
        <a href="/logout" class="btn-signout">🚪 Sign Out</a>
    </div>
</aside>

<main class="main-content">
    <header class="header">
        <h1>Course <span style="color: var(--accent-purple);">Catalog</span></h1>
        <p>Explore your current semester's curriculum and classroom locations.</p>
    </header>

    <div class="courses-grid">
        <% if (courses.length > 0) { %>
            <% courses.forEach(course => { %>
                <article class="course-card">
                    <div class="card-meta">
                        <span class="course-tag"><%= course.course %></span>
                        <span class="room-tag">📍 <%= course.room %></span>
                    </div>

                    <h3 class="course-title"><%= course.subject_name %></h3>
                    
                    <div class="schedule-info">
                        <div class="info-item">
                            <span class="icon">📅</span>
                            <span><%= course.day_of_week %></span>
                        </div>
                        <div class="info-item">
                            <span class="icon">⏰</span>
                            <span><%= course.start_time %> — <%= course.end_time %></span>
                        </div>
                    </div>
                </article>
            <% }); %>
        <% } else { %>
            <div style="grid-column: 1/-1; text-align: center; padding: 80px 20px; background: var(--sidebar-bg); border-radius: 24px; border: 1px dashed rgba(255,255,255,0.1);">
                <div style="font-size: 3rem; margin-bottom: 20px;">📖</div>
                <h3 style="margin-bottom: 10px;">No courses found</h3>
                <p style="color: var(--text-muted);">It looks like the catalog is empty for this semester.</p>
            </div>
        <% } %>
    </div>
</main>

</body>
</html>