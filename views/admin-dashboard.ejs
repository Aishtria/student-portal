<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>StudentHub | Admin Panel</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    
    <style>
        :root {
            --bg-dark: #0f172a;
            --sidebar-bg: #111827;
            --card-bg: #1e293b;
            --accent-purple: #8b5cf6;
            --accent-pink: #d946ef;
            --text-main: #f8fafc;
            --text-muted: #94a3b8;
            --input-bg: #0f172a;
            --border: rgba(255, 255, 255, 0.1);
            --danger: #ef4444;
            --success: #22c55e;
            --sidebar-width: 260px;
            --primary-gradient: linear-gradient(135deg, var(--accent-purple), var(--accent-pink));
        }

        * { box-sizing: border-box; }

        body {
            font-family: 'Inter', sans-serif;
            margin: 0;
            background-color: var(--bg-dark);
            color: var(--text-main);
            display: flex;
            min-height: 100vh;
        }

        /* --- Mobile Toggle --- */
        .mobile-toggle {
            display: none;
            position: fixed;
            top: 20px;
            right: 20px;
            z-index: 2000;
            background: var(--accent-purple);
            border: none;
            color: white;
            padding: 10px;
            border-radius: 8px;
            cursor: pointer;
        }

        /* --- Sidebar Navigation --- */
        .sidebar {
            width: var(--sidebar-width);
            background: var(--sidebar-bg);
            border-right: 1px solid var(--border);
            display: flex;
            flex-direction: column;
            padding: 24px;
            position: fixed;
            height: 100vh;
            z-index: 1000;
            transition: transform 0.3s ease;
        }

        .brand {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 40px;
        }

        .brand-icon {
            background: var(--primary-gradient);
            width: 40px; height: 40px;
            border-radius: 10px;
            display: flex; align-items: center; justify-content: center;
            font-size: 1.2rem;
        }

        .menu-label {
            font-size: 0.7rem;
            text-transform: uppercase;
            color: var(--text-muted);
            letter-spacing: 1px;
            margin: 20px 0 8px 10px;
        }

        .nav-item {
            display: flex; align-items: center; gap: 12px;
            padding: 12px 15px;
            color: var(--text-muted);
            text-decoration: none;
            border-radius: 12px;
            transition: all 0.2s ease;
            margin-bottom: 4px;
            font-size: 0.9rem;
            cursor: pointer;
        }

        .nav-item:hover, .nav-item.active {
            background: rgba(139, 92, 246, 0.1);
            color: var(--text-main);
        }

        .nav-item.active {
            border-left: 4px solid var(--accent-purple);
        }

        /* --- Main Content --- */
        .main-content {
            flex: 1;
            margin-left: var(--sidebar-width);
            padding: 40px;
            transition: margin-left 0.3s ease;
        }

        .content-section {
            display: none;
            animation: fadeIn 0.4s ease-out;
        }

        .content-section.active { display: block; }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .header-bar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 40px;
            gap: 20px;
        }

        .user-profile {
            display: flex; align-items: center; gap: 12px;
            background: var(--card-bg);
            padding: 6px 16px 6px 6px;
            border-radius: 50px;
            border: 1px solid var(--border);
            white-space: nowrap;
        }

        .avatar {
            width: 34px; height: 34px;
            background: var(--accent-purple);
            border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            font-weight: 700; color: white;
        }

        /* --- Cards & Forms --- */
        .card {
            background: var(--card-bg);
            padding: 28px;
            border-radius: 20px;
            border: 1px solid var(--border);
            margin-bottom: 32px;
        }

        .card-title { margin: 0 0 20px 0; font-size: 1.25rem; display: flex; align-items: center; gap: 10px; }

        input, textarea, select {
            width: 100%;
            padding: 12px 16px;
            background: var(--input-bg);
            border: 1px solid var(--border);
            border-radius: 12px;
            color: white;
            margin-bottom: 15px;
            outline: none;
        }

        input:focus { border-color: var(--accent-purple); }

        .btn {
            padding: 12px 24px;
            border-radius: 12px;
            font-weight: 600;
            cursor: pointer;
            border: none;
            transition: 0.3s;
            display: inline-flex; align-items: center;
            text-decoration: none;
        }

        .btn-primary { background: var(--primary-gradient); color: white; width: 100%; justify-content: center; }
        .btn-primary:hover { opacity: 0.9; transform: translateY(-1px); }
        .btn-danger { background: rgba(239, 68, 68, 0.1); color: var(--danger); }
        .btn-danger:hover { background: var(--danger); color: white; }

        /* --- Tables --- */
        .table-responsive {
            background: var(--card-bg);
            border-radius: 20px;
            border: 1px solid var(--border);
            overflow-x: auto;
            margin-bottom: 40px;
        }

        table { width: 100%; border-collapse: collapse; min-width: 600px; }
        th { background: rgba(255,255,255,0.02); color: var(--text-muted); text-align: left; padding: 16px; font-size: 0.75rem; text-transform: uppercase; }
        td { padding: 16px; border-top: 1px solid var(--border); vertical-align: middle; }

        .thumbnail { width: 45px; height: 45px; border-radius: 8px; object-fit: cover; }
        .badge { background: rgba(139, 92, 246, 0.15); color: #a78bfa; padding: 4px 10px; border-radius: 20px; font-size: 0.75rem; font-weight: 600; }

        .schedule-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 15px;
        }

        /* --- Responsive Queries --- */
        @media (max-width: 1024px) {
            .sidebar { transform: translateX(-100%); }
            .sidebar.active { transform: translateX(0); }
            .main-content { margin-left: 0; padding: 80px 20px 20px; }
            .mobile-toggle { display: block; }
        }

        @media (max-width: 640px) {
            .header-bar { flex-direction: column; align-items: flex-start; }
            .user-profile { width: 100%; }
        }
    </style>
</head>
<body>

    <button class="mobile-toggle" onclick="toggleSidebar()">☰</button>

    <aside class="sidebar" id="sidebar">
        <div class="brand">
            <div class="brand-icon">🛡️</div>
            <div>
                <div style="font-weight: 700; font-size: 1.1rem; line-height: 1;">StudentHub</div>
                <div style="font-size: 0.65rem; color: var(--text-muted); margin-top: 4px;">ADMIN PANEL</div>
            </div>
        </div>

        <div class="menu-label">Insights</div>
        <a onclick="showSection('section-dashboard')" class="nav-item active" id="nav-dashboard">📊 Dashboard</a>

        <div class="menu-label">Management</div>
        <a onclick="showSection('section-students')" class="nav-item" id="nav-students">👥 Students</a>
        <a onclick="showSection('section-announcements')" class="nav-item" id="nav-announcements">📢 Announcements</a>
        <a onclick="showSection('section-schedules')" class="nav-item" id="nav-schedules">📅 Class Schedules</a>

        <a href="/logout" class="nav-item" style="margin-top: auto; color: var(--danger);">🚪 Sign Out</a>
    </aside>

    <main class="main-content">
        <header class="header-bar">
            <div>
                <h1 id="page-title" style="margin:0; font-size: 1.8rem;">Dashboard Overview</h1>
                <p style="color: var(--text-muted); margin: 5px 0 0 0;">Control center for portal data.</p>
            </div>
            <div class="user-profile">
                <div class="avatar"><%= user ? user.charAt(0).toUpperCase() : 'A' %></div>
                <div style="font-size: 0.9rem;">Welcome, <strong><%= user %></strong></div>
            </div>
        </header>

        <div id="section-dashboard" class="content-section active">
            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 20px;">
                <section class="card">
                    <h2 class="card-title">📢 Post New Event</h2>
                    <form action="/post-announcement" method="POST" enctype="multipart/form-data">
                        <input type="text" name="title" placeholder="Event Title" required>
                        <textarea name="message" rows="3" placeholder="Event Description..." required></textarea>
                        <label style="font-size: 0.8rem; color: var(--text-muted);">Attach Images</label>
                        <input type="file" name="event_images" accept="image/*" multiple>
                        <button type="submit" class="btn btn-primary">Publish Event →</button>
                    </form>
                </section>

                <section class="card">
                    <h2 class="card-title">📅 Quick Schedule</h2>
                    <form action="/post-schedule" method="POST">
                        <input type="text" name="subject_name" placeholder="Subject Name" required>
                        <div class="schedule-grid">
                            <select name="course" required>
                                <option value="" disabled selected>Course</option>
                                <option value="BSCS">BSCS</option>
                                <option value="BSIS">BSIS</option>
                            </select>
                            <select name="day_of_week" required>
                                <option value="Monday">Monday</option>
                                <option value="Tuesday">Tuesday</option>
                                <option value="Wednesday">Wednesday</option>
                                <option value="Thursday">Thursday</option>
                                <option value="Friday">Friday</option>
                            </select>
                        </div>
                        <div class="schedule-grid" style="margin-top: 10px;">
                            <input type="time" name="start_time" required>
                            <input type="time" name="end_time" required>
                        </div>
                        <input type="text" name="room" placeholder="Room (e.g., Lab 101)" required>
                        <button type="submit" class="btn btn-primary">Save Schedule</button>
                    </form>
                </section>
            </div>
        </div>

        <div id="section-students" class="content-section">
            <div class="table-responsive">
                <table>
                    <thead>
                        <tr><th>Name</th><th>Course</th><th>Year</th><th>Status</th></tr>
                    </thead>
                    <tbody>
                        <% if(students && students.length > 0) { %>
                            <% students.forEach(student => { %>
                                <tr>
                                    <td><strong><%= student.first_name %> <%= student.last_name %></strong></td>
                                    <td><%= student.course %></td>
                                    <td>Year <%= student.year_level %></td>
                                    <td><span class="badge" style="background: rgba(34, 197, 94, 0.1); color: #4ade80;">Active</span></td>
                                </tr>
                            <% }); %>
                        <% } else { %>
                            <tr><td colspan="4" style="text-align: center; color: var(--text-muted); padding: 40px;">No registered students found.</td></tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>

        <div id="section-announcements" class="content-section">
            <div class="table-responsive">
                <table>
                    <thead>
                        <tr><th>Image</th><th>Title</th><th>Date</th><th>Actions</th></tr>
                    </thead>
                    <tbody>
                        <% if(announcements && announcements.length > 0) { %>
                            <% announcements.forEach(post => { %>
                                <tr>
                                    <td>
                                        <% if(post.image) { 
                                            let imgUrl = post.image;
                                            try { 
                                                let imgs = JSON.parse(post.image); 
                                                imgUrl = Array.isArray(imgs) ? imgs[0] : imgs;
                                            } catch(e) {}
                                        %>
                                            <img src="/uploads/<%= imgUrl %>" 
                                            class="thumbnail" 
                                             onerror="this.style.display='none'">
                                        <% } %>
                                    </td>
                                    <td><strong><%= post.title %></strong></td>
                                    <td><%= new Date(post.created_at).toLocaleDateString() %></td>
                                    <td>
                                        <a href="/delete-post/<%= post.id %>" class="btn btn-sm btn-danger" onclick="return confirm('Delete this post?')">Delete</a>
                                    </td>
                                </tr>
                            <% }); %>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>

        <div id="section-schedules" class="content-section">
            <div class="table-responsive">
                <table>
                    <thead>
                        <tr><th>Subject</th><th>Course</th><th>Day & Time</th><th>Room</th><th>Actions</th></tr>
                    </thead>
                    <tbody>
                        <% if(schedules && schedules.length > 0) { %>
                            <% schedules.forEach(s => { %>
                                <tr>
                                    <td><strong><%= s.subject_name %></strong></td>
                                    <td><%= s.course %> (Y<%= s.year_level %>)</td>
                                    <td><%= s.day_of_week %><br><small><%= s.start_time %> - <%= s.end_time %></small></td>
                                    <td><span class="badge"><%= s.room %></span></td>
                                    <td><a href="/delete-schedule/<%= s.id %>" class="btn btn-sm btn-danger">Delete</a></td>
                                </tr>
                            <% }); %>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </main>

    <script>
        function toggleSidebar() {
            document.getElementById('sidebar').classList.toggle('active');
        }

        function showSection(sectionId) {
            // Close mobile sidebar if open
            document.getElementById('sidebar').classList.remove('active');

            // Hide all
            document.querySelectorAll('.content-section').forEach(s => s.classList.remove('active'));
            document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));

            // Show current
            document.getElementById(sectionId).classList.add('active');
            const navId = sectionId.replace('section-', 'nav-');
            if(document.getElementById(navId)) document.getElementById(navId).classList.add('active');

            // Update Title
            const titles = {
                'section-dashboard': 'Dashboard Overview',
                'section-students': 'Registered Students',
                'section-announcements': 'Post Management',
                'section-schedules': 'Academic Schedules'
            };
            document.getElementById('page-title').innerText = titles[sectionId] || 'Admin Panel';
        }
    </script>
</body>
</html>