<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>StudentHub | Admin Panel</title>
    
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    
    <style>
        :root {
            --bg-dark: #0f172a;
            --sidebar-bg: #111827;
            --card-bg: #1e293b;
            --accent-purple: #8b5cf6;
            --accent-pink: #d946ef;
            --text-main: #f8fafc;
            --text-muted: #94a3b8;
            --input-bg: #0f172a;
            --border: rgba(255, 255, 255, 0.1);
            --danger: #ef4444;
            --success: #22c55e;
            --primary-gradient: linear-gradient(135deg, var(--accent-purple), var(--accent-pink));
        }

        * { box-sizing: border-box; }

        body {
            font-family: 'Inter', sans-serif;
            margin: 0;
            background-color: var(--bg-dark);
            color: var(--text-main);
            display: flex;
            min-height: 100vh;
            overflow-x: hidden;
        }

        .sidebar {
            width: 260px;
            background: var(--sidebar-bg);
            border-right: 1px solid var(--border);
            display: flex;
            flex-direction: column;
            padding: 24px;
            position: fixed;
            height: 100vh;
            z-index: 100;
        }

        .brand {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 40px;
        }

        .brand-icon {
            background: var(--primary-gradient);
            width: 40px;
            height: 40px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.2rem;
        }

        .menu-label {
            font-size: 0.7rem;
            text-transform: uppercase;
            color: var(--text-muted);
            letter-spacing: 1px;
            margin: 20px 0 8px 10px;
        }

        .nav-item {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 15px;
            color: var(--text-muted);
            text-decoration: none;
            border-radius: 12px;
            transition: all 0.2s ease;
            margin-bottom: 4px;
            font-size: 0.9rem;
            cursor: pointer;
        }

        .nav-item:hover, .nav-item.active {
            background: rgba(139, 92, 246, 0.1);
            color: var(--text-main);
        }

        .nav-item.active {
            border-left: 4px solid var(--accent-purple);
            background: linear-gradient(to right, rgba(139, 92, 246, 0.1), transparent);
        }

        .content-section {
            display: none;
            animation: fadeIn 0.3s ease-in-out;
        }

        .content-section.active {
            display: block;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .main-content {
            flex: 1;
            margin-left: 260px;
            padding: 40px;
            max-width: 1400px;
        }

        .header-bar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 40px;
        }

        .user-profile {
            display: flex;
            align-items: center;
            gap: 12px;
            background: var(--card-bg);
            padding: 6px 16px 6px 6px;
            border-radius: 50px;
            border: 1px solid var(--border);
        }

        .avatar {
            width: 34px;
            height: 34px;
            background: var(--accent-purple);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            color: white;
        }

        .card {
            background: var(--card-bg);
            padding: 28px;
            border-radius: 20px;
            border: 1px solid var(--border);
            margin-bottom: 32px;
        }

        .card-title {
            margin: 0 0 20px 0;
            font-size: 1.25rem;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        input, textarea, select {
            width: 100%;
            padding: 12px 16px;
            background: var(--input-bg);
            border: 1px solid var(--border);
            border-radius: 12px;
            color: white;
            margin-bottom: 15px;
        }

        .btn {
            padding: 12px 24px;
            border-radius: 12px;
            font-weight: 600;
            cursor: pointer;
            border: none;
            transition: 0.3s;
            display: inline-flex;
            align-items: center;
            text-decoration: none;
        }

        .btn-primary { background: var(--primary-gradient); color: white; width: 100%; justify-content: center; }
        .btn-danger { background: var(--danger); color: white; }
        .btn-sm { padding: 6px 12px; font-size: 0.8rem; }

        .table-responsive {
            background: var(--card-bg);
            border-radius: 20px;
            border: 1px solid var(--border);
            overflow: hidden;
            margin-bottom: 40px;
        }

        table { width: 100%; border-collapse: collapse; }
        th { background: rgba(255,255,255,0.02); color: var(--text-muted); text-align: left; padding: 16px; font-size: 0.75rem; text-transform: uppercase; }
        td { padding: 16px; border-top: 1px solid var(--border); vertical-align: middle; }

        .thumbnail { width: 45px; height: 45px; border-radius: 8px; object-fit: cover; border: 1px solid var(--border); }
        .badge { background: rgba(139, 92, 246, 0.15); color: #a78bfa; padding: 4px 10px; border-radius: 20px; font-size: 0.75rem; font-weight: 600; }

        .schedule-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
            gap: 15px;
        }
    </style>
</head>
<body>

    <aside class="sidebar">
        <div class="brand">
            <div class="brand-icon">🛡️</div>
            <div>
                <div style="font-weight: 700; font-size: 1.1rem; line-height: 1;">StudentHub</div>
                <div style="font-size: 0.65rem; color: var(--text-muted); margin-top: 4px;">ADMIN PANEL</div>
            </div>
        </div>

        <div class="menu-label">Insights</div>
        <a onclick="showSection('section-dashboard')" class="nav-item active" id="nav-dashboard">📊 Dashboard</a>

        <div class="menu-label">Management</div>
        <a onclick="showSection('section-students')" class="nav-item" id="nav-students">👥 Students</a>
        <a onclick="showSection('section-announcements')" class="nav-item" id="nav-announcements">📢 Announcements</a>
        <a onclick="showSection('section-schedules')" class="nav-item" id="nav-schedules">📅 Class Schedules</a>

        <a href="/logout" class="nav-item" style="margin-top: auto; color: var(--danger);">🚪 Sign Out</a>
    </aside>

    <main class="main-content">
        
        <header class="header-bar">
            <div>
                <h1 id="page-title" style="margin:0; font-size: 1.8rem;">Dashboard Overview</h1>
                <p style="color: var(--text-muted); margin: 5px 0 0 0;">Manage your portal systems and data.</p>
            </div>
            <div class="user-profile">
                <div class="avatar"><%= user ? user.charAt(0).toUpperCase() : 'A' %></div>
                <div style="font-size: 0.9rem;">Welcome, <strong><%= user %></strong></div>
            </div>
        </header>

        <div id="section-dashboard" class="content-section active">
            <section class="card">
                <h2 class="card-title">📢 Post New Event</h2>
                <form action="/post-announcement" method="POST" enctype="multipart/form-data">
                    <input type="text" name="title" placeholder="Event Title" required>
                    <textarea name="message" rows="3" placeholder="Event Description..." required></textarea>
                    <input type="file" name="event_images" accept="image/*" multiple>
                    <button type="submit" class="btn btn-primary">Publish Event →</button>
                </form>
            </section>

            <section class="card">
                <h2 class="card-title">📅 New Class Schedule</h2>
                <form action="/post-schedule" method="POST">
                    <div class="schedule-grid">
                        <select name="course" required>
                            <option value="" disabled selected>Select Course</option>
                            <option value="BS Computer Science">BS Computer Science</option>
                            <option value="BS Information Systems">BS Information Systems</option>
                            <option value="BS Criminology">BS Criminology</option>
                        </select>
                        <select name="year_level" required>
                            <option value="1">1st Year</option>
                            <option value="2">2nd Year</option>
                            <option value="3">3rd Year</option>
                            <option value="4">4th Year</option>
                        </select>
                        <input type="text" name="subject_name" placeholder="Subject Code/Name" required>
                        <select name="day_of_week" required>
                            <option value="Monday">Monday</option>
                            <option value="Tuesday">Tuesday</option>
                            <option value="Wednesday">Wednesday</option>
                            <option value="Thursday">Thursday</option>
                            <option value="Friday">Friday</option>
                        </select>
                        <input type="time" name="start_time" required>
                        <input type="time" name="end_time" required>
                        <input type="text" name="room" placeholder="Room" required>
                    </div>
                    <button type="submit" class="btn btn-primary" style="margin-top: 10px;">Save Schedule</button>
                </form>
            </section>
        </div>

        <div id="section-students" class="content-section">
            <h2 class="card-title">👥 Registered Students</h2>
            <div class="table-responsive">
                <table>
                    <thead>
                        <tr><th>Name</th><th>Course</th><th>Year</th><th>Status</th></tr>
                    </thead>
                    <tbody>
                        <% if(students && students.length > 0) { %>
                            <% students.forEach(student => { %>
                                <tr>
                                    <td><strong><%= student.first_name %> <%= student.last_name %></strong></td>
                                    <td><%= student.course %></td>
                                    <td>Year <%= student.year_level %></td>
                                    <td><span class="badge" style="background: rgba(34, 197, 94, 0.1); color: #4ade80;">Active</span></td>
                                </tr>
                            <% }); %>
                        <% } else { %>
                            <tr><td colspan="4" style="text-align: center; color: var(--text-muted);">No students registered yet.</td></tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>

        <div id="section-announcements" class="content-section">
            <h2 class="card-title">📢 Manage Postings</h2>
            <div class="table-responsive">
                <table>
                    <thead>
                        <tr><th>Images</th><th>Title</th><th>Date Posted</th><th>Actions</th></tr>
                    </thead>
                    <tbody>
                        <% if(announcements && announcements.length > 0) { %>
                            <% announcements.forEach(post => { %>
                                <tr>
                                    <td>
                                        <div style="display: flex; gap: 5px;">
                                            <% if(post.image) { 
                                                try {
                                                    let images = JSON.parse(post.image);
                                                    if(Array.isArray(images)) {
                                                        images.forEach(img => { %>
                                                            <img src="/uploads/<%= img %>" class="thumbnail">
                                                        <% });
                                                    } else { %>
                                                        <img src="/uploads/<%= post.image %>" class="thumbnail">
                                                    <% }
                                                } catch(e) { %>
                                                    <img src="/uploads/<%= post.image %>" class="thumbnail">
                                                <% } 
                                            } else { %>
                                                <span style="color:var(--text-muted); font-size: 0.7rem;">None</span>
                                            <% } %>
                                        </div>
                                    </td>
                                    <td><strong><%= post.title %></strong></td>
                                    <td style="color: var(--text-muted);"><%= new Date(post.created_at).toLocaleDateString() %></td>
                                    <td>
                                        <a href="/delete-post/<%= post.id %>" class="btn btn-sm btn-danger" onclick="return confirm('Delete this announcement?')">Delete</a>
                                    </td>
                                </tr>
                            <% }); %>
                        <% } else { %>
                            <tr><td colspan="4" style="text-align:center; color: var(--text-muted);">No announcements found.</td></tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>

        <div id="section-schedules" class="content-section">
            <h2 class="card-title">📅 Managed Schedules</h2>
            <div class="table-responsive">
                <table>
                    <thead>
                        <tr><th>Subject</th><th>Course & Year</th><th>Day & Time</th><th>Room</th><th>Actions</th></tr>
                    </thead>
                    <tbody>
                        <% if(schedules && schedules.length > 0) { %>
                            <% schedules.forEach(s => { %>
                                <tr>
                                    <td><strong><%= s.subject_name %></strong></td>
                                    <td><%= s.course %> - Y<%= s.year_level %></td>
                                    <td><%= s.day_of_week %> <br> <small><%= s.start_time %> - <%= s.end_time %></small></td>
                                    <td><span class="badge"><%= s.room %></span></td>
                                    <td>
                                        <a href="/delete-schedule/<%= s.id %>" class="btn btn-sm btn-danger" onclick="return confirm('Delete this schedule?')">Delete</a>
                                    </td>
                                </tr>
                            <% }); %>
                        <% } else { %>
                            <tr><td colspan="5" style="text-align:center; color: var(--text-muted);">No schedules found.</td></tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>

    </main>

    <script>
        function showSection(sectionId) {
            document.querySelectorAll('.content-section').forEach(section => {
                section.classList.remove('active');
            });

            document.getElementById(sectionId).classList.add('active');

            document.querySelectorAll('.nav-item').forEach(item => {
                item.classList.remove('active');
            });
            const navId = sectionId.replace('section-', 'nav-');
            if(document.getElementById(navId)) {
                document.getElementById(navId).classList.add('active');
            }

            const titles = {
                'section-dashboard': 'Dashboard Overview',
                'section-students': 'Registered Students',
                'section-announcements': 'Event Announcements',
                'section-schedules': 'Class Schedules'
            };
            document.getElementById('page-title').innerText = titles[sectionId] || 'Admin Panel';
        }
    </script>
</body>
</html>